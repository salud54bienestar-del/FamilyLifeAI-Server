// Sistema de etapas de vida - Village Soul

const cargarArchivo = require("./cargador_datos.js");



// =================================
// OBTENER ETAPA POR EDAD
// =================================

function obtenerEtapaPorEdad(edad){


    const datos =
    cargarArchivo("../datos/etapas_vida.json");


    if(!datos){

        console.log(
            "No se pudieron cargar las etapas de vida."
        );

        return null;

    }



    const etapa =
    datos.etapas.find(

        e =>

        edad >= e.edad_minima &&
        edad <= e.edad_maxima

    );



    return etapa || null;

}




// =================================
// OBTENER ETAPA DE HABITANTE
// =================================

function obtenerEtapaHabitante(habitante){


    if(!habitante){

        return null;

    }



    return obtenerEtapaPorEdad(

        habitante.edad || 0

    );

}





// =================================
// ACTUALIZAR ETAPA
// =================================

function actualizarEtapa(habitante){


    if(!habitante){

        return null;

    }



    const etapa =
    obtenerEtapaHabitante(
        habitante
    );



    if(etapa){

        habitante.etapa =
        etapa.nombre;

    }



    return habitante;

}





// =================================
// DESCRIPCIÓN
// =================================

function obtenerDescripcionEtapa(habitante){


    const etapa =
    obtenerEtapaHabitante(
        habitante
    );



    if(!etapa){

        return "Sin etapa definida";

    }



    return etapa.descripcion;

}





module.exports = {


    obtenerEtapaPorEdad,

    obtenerEtapaHabitante,

    actualizarEtapa,

    obtenerDescripcionEtapa


};
