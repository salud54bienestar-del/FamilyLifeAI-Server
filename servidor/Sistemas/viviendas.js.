// Sistema de viviendas - Village Soul 2.0

const cargarArchivo = require("./cargador_datos.js");
const guardarArchivo = require("./guardador_datos.js");
const crearEvento = require("./eventos.js");
const crearMemoria = require("./memorias.js");

// =================================
// OBTENER VIVIENDA
// =================================

function obtenerVivienda(id) {
    const datos = cargarArchivo("../datos/viviendas.json");

    if (!datos || !datos.viviendas) {
        console.log("No se pudieron cargar las viviendas.");
        return null;
    }

    return datos.viviendas.find(vivienda => vivienda.id === id) || null;
}

// =================================
// LISTAR VIVIENDAS
// =================================

function listarViviendas() {
    const datos = cargarArchivo("../datos/viviendas.json");

    if (!datos || !datos.viviendas) {
        return [];
    }

    return datos.viviendas;
}

// =================================
// CREAR VIVIENDA
// =================================

function crearVivienda(nombre, tipo = "casa") {
    const datos = cargarArchivo("../datos/viviendas.json") || { viviendas: [] };

    if (!Array.isArray(datos.viviendas)) {
        datos.viviendas = [];
    }

    const nuevoId = datos.viviendas.length > 0
        ? Math.max(...datos.viviendas.map(v => v.id)) + 1
        : 1;

    const vivienda = {
        id: nuevoId,
        nombre,
        tipo,
        estado: "desocupada",
        familia_id: null,
        habitantes: [],
        ubicacion: {
            dimension: "overworld",
            x: 0,
            y: 64,
            z: 0
        },
        habitaciones: {
            dormitorios: 1,
            baños: 1,
            cocina: 1,
            sala: 1
        },
        camas: 2,
        capacidad: 2,
        inventario: {
            alimentos: 0,
            agua: 0,
            herramientas: [],
            materiales: []
        },
        nivel: 1,
        seguridad: 100,
        limpieza: 100,
        energia: 100
    };

    datos.viviendas.push(vivienda);
    guardarArchivo("../datos/viviendas.json", datos);

    crearEvento("vivienda_creada", [], {
        sistema: "viviendas",
        accion: "crear_vivienda",
        vivienda_id: nuevoId,
        nombre: vivienda.nombre
    });

    console.log("🏠 Vivienda creada:", vivienda.nombre);

    return vivienda;
}

// =================================
// ASIGNAR FAMILIA
// =================================

function asignarFamilia(vivienda_id, familia_id) {
    const datos = cargarArchivo("../datos/viviendas.json");

    if (!datos || !datos.viviendas) {
        return null;
    }

    const vivienda = datos.viviendas.find(v => v.id === vivienda_id);

    if (!vivienda) {
        console.log("Vivienda no encontrada.");
        return null;
    }

    vivienda.familia_id = familia_id;
    vivienda.estado = "habitada";

    guardarArchivo("../datos/viviendas.json", datos);

    return vivienda;
}

// =================================
// AGREGAR HABITANTE
// =================================

function agregarHabitante(vivienda_id, habitante_id) {
    const datos = cargarArchivo("../datos/viviendas.json");

    if (!datos || !datos.viviendas) {
        return null;
    }

    const vivienda = datos.viviendas.find(v => v.id === vivienda_id);

    if (!vivienda) {
        console.log("Vivienda no encontrada.");
        return null;
    }

    if (!Array.isArray(vivienda.habitantes)) {
        vivienda.habitantes = [];
    }

    if (vivienda.habitantes.includes(habitante_id)) {
        return vivienda;
    }

    if (vivienda.habitantes.length >= vivienda.capacidad) {
        console.log("La vivienda está llena.");
        return null;
    }

    vivienda.habitantes.push(habitante_id);

    if (vivienda.estado === "desocupada") {
        vivienda.estado = "habitada";
    }

    guardarArchivo("../datos/viviendas.json", datos);

    crearMemoria(
        habitante_id,
        "vivienda",
        "Ahora vive en " + vivienda.nombre,
        "media"
    );

    return vivienda;
}

// =================================
// QUITAR HABITANTE
// =================================

function quitarHabitante(vivienda_id, habitante_id) {
    const datos = cargarArchivo("../datos/viviendas.json");

    if (!datos || !datos.viviendas) {
        return null;
    }

    const vivienda = datos.viviendas.find(v => v.id === vivienda_id);

    if (!vivienda) {
        return null;
    }

    if (Array.isArray(vivienda.habitantes)) {
        vivienda.habitantes = vivienda.habitantes.filter(id => id !== habitante_id);
    }

    if (vivienda.habitantes.length === 0 && !vivienda.familia_id) {
        vivienda.estado = "desocupada";
    }

    guardarArchivo("../datos/viviendas.json", datos);

    return vivienda;
}

// =================================
// EXPORTACIÓN DE MÓDULOS
// =================================

module.exports = {
    obtenerVivienda,
    listarViviendas,
    crearVivienda,
    asignarFamilia,
    agregarHabitante,
    quitarHabitante
};
