const fs = require("fs");

function cargarArchivo(nombre) {
  try {
    const datos = fs.readFileSync(nombre, "utf8");
    return JSON.parse(datos);
  } catch (error) {
    console.log("No se pudo cargar: " + nombre);
    return null;
  }
}

console.log("Cargador de datos iniciado.");

module.exports = cargarArchivo;
